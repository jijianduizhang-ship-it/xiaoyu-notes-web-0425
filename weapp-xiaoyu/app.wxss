page {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  background: linear-gradient(180deg, #E6F7F2 0%, #F5FFFA 100%);
  min-height: 100vh;
}
.container {
  padding: 20rpx;
}
.btn-primary {
  background: linear-gradient(90deg, #00E0B0 0%, #00A8E0 100%);
  color: #fff;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  margin: 20rpx 0;
}
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
}
.tag-active {
  background: #00C896;
  color: #fff;
}
.tag-default {
  background: #F5F5F5;
  color: #666;
}
