.container {
  padding: 30rpx;
  background: #F5F5F5;
  min-height: 100vh;
}
.lang-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}
.lang-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 30rpx;
}
.lang-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 50rpx;
}
.lang-item {
  width: 30%;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}
.lang-item.active {
  border-color: #00C896;
  background: #E6F7F2;
}
.lang-flag {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}
.lang-name {
  font-size: 28rpx;
  color: #333;
}
.level-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}
.level-desc {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 20rpx;
}
.level-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 50rpx;
}
.level-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}
.level-item.active {
  border-color: #00C896;
  background: #E6F7F2;
}
.level-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
}
.level-desc-text {
  font-size: 24rpx;
  color: #666;
}
.save-btn {
  background: linear-gradient(135deg, #00C896, #00A878);
  color: #fff;
  padding: 24rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 200, 150, 0.3);
}
.save-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}
