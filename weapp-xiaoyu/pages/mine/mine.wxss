/* 我的页面样式 */
.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 120rpx;
}

.mine-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 0 0 40rpx 40rpx;
  padding: 30rpx 30rpx 40rpx;
  margin: -20rpx -20rpx 0 -20rpx;
}

.add-tip {
  background: rgba(255,255,255,0.2);
  color: #fff;
  padding: 12rpx 20rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

/* 登录入口 */
.login-box {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 24rpx;
  margin-bottom: 20rpx;
}

.login-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  margin-right: 24rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.login-info {
  flex: 1;
}

.login-text {
  font-size: 34rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.login-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.login-arrow {
  font-size: 48rpx;
  color: #fff;
  opacity: 0.8;
}

/* 用户信息 */
.user-info {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #fff;
  margin-right: 24rpx;
  position: relative;
  overflow: visible;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-avatar .avatar-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
}

.vip-badge {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #fff;
  font-size: 18rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
  white-space: nowrap;
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.edit-tip {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
}

/* 学习数据 */
.data-box {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  margin-bottom: 20rpx;
}

.data-item {
  text-align: center;
  flex: 1;
}

.data-num {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 6rpx;
}

.data-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
}

.data-divider {
  width: 1rpx;
  height: 50rpx;
  background: rgba(255,255,255,0.3);
}

/* 会员卡片 */
.member-card {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFE0B2 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
}

.member-icon {
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.member-left {
  flex: 1;
}

.member-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.member-desc {
  font-size: 22rpx;
  color: #666;
}

.member-btn {
  background: linear-gradient(135deg, #FF6B6B, #FF4757);
  color: #fff;
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 功能菜单 */
.menu-list {
  padding: 30rpx 20rpx 0;
}

.menu-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.menu-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: #F8F8F8;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 36rpx;
}

.icon-gift { background: #FFF1F0; }
.icon-star { background: #FFFBE6; }
.icon-bookmark { background: #E6FFF7; }
.icon-share { background: #F0F0FF; }
.icon-promo { background: #FFF7E6; }
.icon-settings { background: #F5F5F5; }
.icon-service { background: #F0F9FF; }

.menu-content {
  flex: 1;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 16rpx;
}

.logout-item {
  margin-top: 30rpx;
}

.logout-icon {
  background: #FFF1F0 !important;
}

.logout-text {
  color: #FF4D4F !important;
}

/* 底部版权 */
.footer {
  text-align: center;
  padding: 40rpx 0;
  font-size: 22rpx;
  color: #ccc;
}
